# Changing Window Focus

cmd - return : osascript -e 'tell application "Ghostty" to make new window' -e 'tell application "Ghostty" to activate'
cmd - b : osascript -e 'tell application "Brave Browser" to make new window' -e 'tell application "Brave Browser" to activate'
cmd - e : osascript -e 'tell application "Finder" to make new Finder window' -e 'tell application "Finder" to activate'

# change window focus within space
cmd - h : yabai -m window --focus west
cmd - j : yabai -m window --focus south
cmd - k : yabai -m window --focus north
cmd - l : yabai -m window --focus east

alt - c : ~/.config/skhd/toggle-caffeine.sh

# toggle menu bar opacity (0% <-> 100%) -- not macOS auto-hide
cmd + shift - m : ~/.config/skhd/toggle-menubar.sh

# move windows
cmd + shift - h : yabai -m window --swap west; yabai -m window --focus east; yabai -m window --focus west
cmd + shift - j : yabai -m window --swap south; yabai -m window --focus north; yabai -m window --focus south
cmd + shift - k : yabai -m window --swap north; yabai -m window --focus south; yabai -m window --focus north
cmd + shift - l : yabai -m window --swap east; yabai -m window --focus west; yabai -m window --focus east

# move window and split
ctrl + alt - h : yabai -m window --warp west; yabai -m window --focus east; yabai -m window --focus west
ctrl + alt - j : yabai -m window --warp south; yabai -m window --focus north; yabai -m window --focus south
ctrl + alt - k : yabai -m window --warp north; yabai -m window --focus south; yabai -m window --focus north
ctrl + alt - l : yabai -m window --warp east; yabai -m window --focus west; yabai -m window --focus east

shift + ctrl - v [
    "Ghostty" : skhd -k "cmd - v"
    "Brave Browser" : skhd -k "cmd - v"
    * ~
]

# use ctrl+t for new tabs (cmd+t is toggle theme)
ctrl - t [
    "Brave Browser" : osascript -e 'tell app "Brave Browser" to tell front window to make new tab'
    # "Google Chrome" : osascript -e 'tell app "Google Chrome" to tell front window to make new tab'
    "Chromium"      : osascript -e 'tell app "Chromium" to tell front window to make new tab'
    * ~
]

# use ctrl+n for new windows
ctrl - n [
    "Brave Browser" : skhd -k "cmd - n"
    # "Google Chrome" : skhd -k "cmd - n"
    "Chromium"      : skhd -k "cmd - n"
    * ~
]

# use ctrl+w for closing tabs/windows
ctrl - w [
    "Brave Browser" : skhd -k "cmd - w"
    # "Google Chrome" : skhd -k "cmd - w"
    "Chromium"      : skhd -k "cmd - w"
    * ~
]

# use ctrl+a for select all
ctrl - a [
    "Brave Browser" : skhd -k "cmd - a"
    # "Google Chrome" : skhd -k "cmd - a"
    "Chromium"      : skhd -k "cmd - a"
    * ~
]

# use ctrl+z for undo
ctrl - z [
    "Brave Browser" : skhd -k "cmd - z"
    # "Google Chrome" : skhd -k "cmd - z"
    "Chromium"      : skhd -k "cmd - z"
    * ~
]

# use ctrl+backspace for deleting one word at a time
ctrl - backspace [
    "Brave Browser" : skhd -k "alt - backspace"
    # "Google Chrome" : skhd -k "alt - backspace"
    "Chromium"      : skhd -k "alt - backspace"
    * ~
]

# use ctrl+left for back-tracking one word at a time
ctrl - left [
    "Brave Browser" : skhd -k "alt - left"
    # "Google Chrome" : skhd -k "alt - left"
    "Chromium"      : skhd -k "alt - left"
    * ~
]

# use ctrl+right for progressing one word at a time
ctrl - right [
    "Brave Browser" : skhd -k "alt - right"
    # "Google Chrome" : skhd -k "alt - right"
    "Chromium"      : skhd -k "alt - right"
    * ~
]

# toggle dark/light mode
cmd - t : osascript -e 'tell app "System Events" to tell appearance preferences to set dark mode to not dark mode'

# change focus between external displays (left and right)
# alt - s : yabai -m display --focus west
# alt - g : yabai -m display --focus east

# Modifying the Layout

# rotate layout clockwise
shift + alt - r : yabai -m space --rotate 270

# flip along y-axis
shift + alt - y : yabai -m space --mirror y-axis

# flip along x-axis
shift + alt - x : yabai -m space --mirror x-axis

# toggle window float
shift + alt - t : yabai -m window --toggle float --grid 4:4:1:1:2:2


# modifying window size

# maximize a window
shift + alt - m : yabai -m window --toggle zoom-fullscreen

# balance out tree of windows (resize to occupy same area)
shift + alt - e : yabai -m space --balance

# move window to display left and right
shift + alt - s : yabai -m window --display west; yabai -m display --focus west
shift + alt - g : yabai -m window --display east; yabai -m display --focus east

# move window to prev and next space
shift + alt - p : yabai -m window --space prev
shift + alt - n : yabai -m window --space next


# move to space #
cmd - 1 : yabai -m space --focus 1
cmd - 2 : yabai -m space --focus 2
cmd - 3 : yabai -m space --focus 3
cmd - 4 : yabai -m space --focus 4
cmd - 5 : yabai -m space --focus 5
cmd - 6 : yabai -m space --focus 6
cmd - 7 : yabai -m space --focus 7
cmd - 8 : yabai -m space --focus 8
cmd - 9 : yabai -m space --focus 9
cmd - 0 : yabai -m space --focus 10

# move window to space # and follow it
cmd + shift - 1 : yabai -m window --space 1; yabai -m space --focus 1
cmd + shift - 2 : yabai -m window --space 2; yabai -m space --focus 2
cmd + shift - 3 : yabai -m window --space 3; yabai -m space --focus 3
cmd + shift - 4 : yabai -m window --space 4; yabai -m space --focus 4
cmd + shift - 5 : yabai -m window --space 5; yabai -m space --focus 5
cmd + shift - 6 : yabai -m window --space 6; yabai -m space --focus 6
cmd + shift - 7 : yabai -m window --space 7; yabai -m space --focus 7
cmd + shift - 8 : yabai -m window --space 8; yabai -m space --focus 8
cmd + shift - 9 : yabai -m window --space 9; yabai -m space --focus 9
cmd + shift - 0 : yabai -m window --space 10; yabai -m space --focus 10

# start/stopping yabai

# -- start/stop yabai ---
ctrl + alt - q : brew services stop yabai
ctrl + alt - s : brew services start yabai

# Changing Window Focus

.alias $super rcmd + rctrl + ralt

$super - return : osascript -e 'tell application "Ghostty" to make new window' -e 'tell application "Ghostty" to activate'
$super - b : osascript -e 'tell application "Brave Browser" to make new window' -e 'tell application "Brave Browser" to activate'
$super - e : osascript -e 'tell application "Finder" to make new Finder window' -e 'tell application "Finder" to activate'

# change window focus within space (fallback to change focus across displays)
$super - h : ~/.config/skhd/change-focus.sh --west
$super - j : ~/.config/skhd/change-focus.sh --south
$super - k : ~/.config/skhd/change-focus.sh --north
$super - l : ~/.config/skhd/change-focus.sh --east

# move windows
$super + shift - h : ~/.config/skhd/swap-window.sh --west
$super + shift - j : ~/.config/skhd/swap-window.sh --south
$super + shift - k : ~/.config/skhd/swap-window.sh --north
$super + shift - l : ~/.config/skhd/swap-window.sh --east

# resize focused window (shift the edge in the arrow's direction)
$super + shift - left  : yabai -m window --resize left:-50:0 ; yabai -m window --resize right:-50:0
$super + shift - down  : yabai -m window --resize bottom:0:50 ; yabai -m window --resize top:0:50
$super + shift - right : yabai -m window --resize right:50:0 ; yabai -m window --resize left:50:0
$super + shift - up    : yabai -m window --resize top:0:-50 ; yabai -m window --resize bottom:0:-50

# move window and split
ctrl + alt - h : ~/.config/skhd/warp-window.sh --west
ctrl + alt - j : ~/.config/skhd/warp-window.sh --south
ctrl + alt - k : ~/.config/skhd/warp-window.sh --north
ctrl + alt - l : ~/.config/skhd/warp-window.sh --east

# toggle dark/light mode
$super - t : osascript -e 'tell app "System Events" to tell appearance preferences to set dark mode to not dark mode'
$super - c : ~/.config/skhd/toggle-caffeine.sh
$super - m : ~/.config/skhd/toggle-menubar.sh

# change focus between external displays (left and right)
# alt - s : yabai -m display --focus west
# alt - g : yabai -m display --focus east

# Modifying the Layout

# rotate layout clockwise
shift + alt - r : yabai -m space --rotate 270

# flip along y-axis
shift + alt - y : yabai -m space --mirror y-axis

# flip along x-axis
shift + alt - x : yabai -m space --mirror x-axis

# toggle window float
shift + alt - t : yabai -m window --toggle float --grid 4:4:1:1:2:2


# modifying window size

# maximize a window
shift + alt - m : yabai -m window --toggle zoom-fullscreen

# balance out tree of windows (resize to occupy same area)
shift + alt - e : yabai -m space --balance

# move window to display left and right
shift + alt - s : yabai -m window --display west; yabai -m display --focus west
shift + alt - g : yabai -m window --display east; yabai -m display --focus east

# move window to prev and next space
shift + alt - p : yabai -m window --space prev
shift + alt - n : yabai -m window --space next


# move to space # (logical chain: ultrawide -> macbook -> external)
$super - 1 : ~/.config/skhd/logical-space/logical-space --focus 1
$super - 2 : ~/.config/skhd/logical-space/logical-space --focus 2
$super - 3 : ~/.config/skhd/logical-space/logical-space --focus 3
$super - 4 : ~/.config/skhd/logical-space/logical-space --focus 4
$super - 5 : ~/.config/skhd/logical-space/logical-space --focus 5
$super - 6 : ~/.config/skhd/logical-space/logical-space --focus 6
$super - 7 : ~/.config/skhd/logical-space/logical-space --focus 7
$super - 8 : ~/.config/skhd/logical-space/logical-space --focus 8
$super - 9 : ~/.config/skhd/logical-space/logical-space --focus 9
$super - 0 : ~/.config/skhd/logical-space/logical-space --focus 10

# move window to space # and follow it (same logical chain)
$super + shift - 1 : ~/.config/skhd/logical-space/logical-space --move 1
$super + shift - 2 : ~/.config/skhd/logical-space/logical-space --move 2
$super + shift - 3 : ~/.config/skhd/logical-space/logical-space --move 3
$super + shift - 4 : ~/.config/skhd/logical-space/logical-space --move 4
$super + shift - 5 : ~/.config/skhd/logical-space/logical-space --move 5
$super + shift - 6 : ~/.config/skhd/logical-space/logical-space --move 6
$super + shift - 7 : ~/.config/skhd/logical-space/logical-space --move 7
$super + shift - 8 : ~/.config/skhd/logical-space/logical-space --move 8
$super + shift - 9 : ~/.config/skhd/logical-space/logical-space --move 9
$super + shift - 0 : ~/.config/skhd/logical-space/logical-space --move 10

# start/stopping yabai

# -- start/stop yabai ---
ctrl + alt - q : brew services stop yabai
ctrl + alt - s : brew services start yabai

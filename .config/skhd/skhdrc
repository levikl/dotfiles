# Changing Window Focus

.alias $super rcmd + rctrl + ralt

$super - return : osascript -e 'tell application "Ghostty" to make new window' -e 'tell application "Ghostty" to activate'
$super - b : osascript -e 'tell application "Brave Browser" to make new window' -e 'tell application "Brave Browser" to activate'
$super - e : osascript -e 'tell application "Finder" to make new Finder window' -e 'tell application "Finder" to activate'

# change window focus within space (fallback to change focus across displays)
$super - h : ~/.config/skhd/change-focus.sh --west
$super - j : ~/.config/skhd/change-focus.sh --south
$super - k : ~/.config/skhd/change-focus.sh --north
$super - l : ~/.config/skhd/change-focus.sh --east

# move windows
$super + shift - h : yabai -m window --swap west; yabai -m window --focus east; yabai -m window --focus west
$super + shift - j : yabai -m window --swap south; yabai -m window --focus north; yabai -m window --focus south
$super + shift - k : yabai -m window --swap north; yabai -m window --focus south; yabai -m window --focus north
$super + shift - l : yabai -m window --swap east; yabai -m window --focus west; yabai -m window --focus east

# move window and split
ctrl + alt - h : yabai -m window --warp west; yabai -m window --focus east; yabai -m window --focus west
ctrl + alt - j : yabai -m window --warp south; yabai -m window --focus north; yabai -m window --focus south
ctrl + alt - k : yabai -m window --warp north; yabai -m window --focus south; yabai -m window --focus north
ctrl + alt - l : yabai -m window --warp east; yabai -m window --focus west; yabai -m window --focus east

# toggle dark/light mode
$super - t : osascript -e 'tell app "System Events" to tell appearance preferences to set dark mode to not dark mode'
$super - c : ~/.config/skhd/toggle-caffeine.sh
$super - m : ~/.config/skhd/toggle-menubar.sh

# change focus between external displays (left and right)
# alt - s : yabai -m display --focus west
# alt - g : yabai -m display --focus east

# Modifying the Layout

# rotate layout clockwise
shift + alt - r : yabai -m space --rotate 270

# flip along y-axis
shift + alt - y : yabai -m space --mirror y-axis

# flip along x-axis
shift + alt - x : yabai -m space --mirror x-axis

# toggle window float
shift + alt - t : yabai -m window --toggle float --grid 4:4:1:1:2:2


# modifying window size

# maximize a window
shift + alt - m : yabai -m window --toggle zoom-fullscreen

# balance out tree of windows (resize to occupy same area)
shift + alt - e : yabai -m space --balance

# move window to display left and right
shift + alt - s : yabai -m window --display west; yabai -m display --focus west
shift + alt - g : yabai -m window --display east; yabai -m display --focus east

# move window to prev and next space
shift + alt - p : yabai -m window --space prev
shift + alt - n : yabai -m window --space next


# move to space #
$super - 1 : yabai -m space --focus 1
$super - 2 : yabai -m space --focus 2
$super - 3 : yabai -m space --focus 3
$super - 4 : yabai -m space --focus 4
$super - 5 : yabai -m space --focus 5
$super - 6 : yabai -m space --focus 6
$super - 7 : yabai -m space --focus 7
$super - 8 : yabai -m space --focus 8
$super - 9 : yabai -m space --focus 9
$super - 0 : yabai -m space --focus 10

# move window to space # and follow it
$super + shift - 1 : yabai -m window --space 1; yabai -m space --focus 1
$super + shift - 2 : yabai -m window --space 2; yabai -m space --focus 2
$super + shift - 3 : yabai -m window --space 3; yabai -m space --focus 3
$super + shift - 4 : yabai -m window --space 4; yabai -m space --focus 4
$super + shift - 5 : yabai -m window --space 5; yabai -m space --focus 5
$super + shift - 6 : yabai -m window --space 6; yabai -m space --focus 6
$super + shift - 7 : yabai -m window --space 7; yabai -m space --focus 7
$super + shift - 8 : yabai -m window --space 8; yabai -m space --focus 8
$super + shift - 9 : yabai -m window --space 9; yabai -m space --focus 9
$super + shift - 0 : yabai -m window --space 10; yabai -m space --focus 10

# start/stopping yabai

# -- start/stop yabai ---
ctrl + alt - q : brew services stop yabai
ctrl + alt - s : brew services start yabai
